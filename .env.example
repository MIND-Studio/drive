# Pod base URL — the shared Mind CSS (`docker compose up` at the workspace
# root; see ../SOLID-SERVER.md). Every pod URL flows through this var.
NEXT_PUBLIC_POD_BASE_URL=http://localhost:3011/

# Namespace this prototype claims under each user pod.
# A shared-CSS scenario relies on each prototype claiming a distinct path.
NEXT_PUBLIC_DRIVE_NAMESPACE=mind-drive

# App-owned, public-append feedback inbox. Defaults to <pod>/alice/drive-feedback/.
NEXT_PUBLIC_FEEDBACK_INBOX=http://localhost:3011/alice/drive-feedback/
