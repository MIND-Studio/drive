# Pod base URL. Defaults to local CSS on port 3061.
# To point all prototypes at one shared CSS, change this here and in the
# sibling prototypes' env files — every pod URL flows through this var.
NEXT_PUBLIC_POD_BASE_URL=http://localhost:3061/

# Namespace this prototype claims under each user pod.
# A shared-CSS scenario relies on each prototype claiming a distinct path.
NEXT_PUBLIC_DRIVE_NAMESPACE=mind-drive
